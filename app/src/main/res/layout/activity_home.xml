<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111114">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <RelativeLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="450dp">

                <ImageView
                    android:id="@+id/heroImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="matrix"
                    android:src="#222222" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#44000000" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_gradient" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="32dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_alignParentStart="true"
                        android:gravity="center_vertical">

                        <TextView android:id="@+id/menuPesquisar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pesquisar" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="16dp"/>
                        <TextView android:id="@+id/menuInicio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="16dp"/>
                        <TextView android:id="@+id/menuCanais" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais de TV" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="16dp"/>
                        <TextView android:id="@+id/menuFilmes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Filmes" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="16dp"/>
                        <TextView android:id="@+id/menuSeries" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="16dp"/>
                        <TextView android:id="@+id/menuEsportes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Esportes" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/menuConfig"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Configurações"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/bg_menu_focus"
                        android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="8dp" android:paddingBottom="8dp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="600dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical"
                    android:paddingStart="48dp"
                    android:paddingEnd="48dp"
                    android:paddingBottom="48dp">

                    <TextView android:id="@+id/heroBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CARREGANDO..." android:textColor="#FFC107" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/heroTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aguarde" android:textColor="#FFFFFF" android:textSize="42sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/heroDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conectando ao servidor..." android:textColor="#CCCCCC" android:textSize="16sp" android:layout_marginBottom="24dp"/>
                    <Button android:id="@+id/btnAssistirDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:text="ASSISTIR AGORA" android:textStyle="bold" android:paddingStart="32dp" android:paddingEnd="32dp" android:visibility="gone" />
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_below="@id/heroSection"
                android:paddingStart="48dp"
                android:paddingTop="24dp"
                android:paddingBottom="48dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView android:id="@+id/tvContinuarTitulo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Continuar Assistindo" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" android:visibility="gone" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerContinuar" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" android:visibility="gone" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais Favoritos" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerFavoritos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Últimos Adicionados" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerUltimos" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top 10 Filmes" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerTopFilmes" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />
                    
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries em Alta" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerSeriesAlta" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top 10 Séries" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerTopSeries" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />
            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#111114"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerInParent="true"
            android:gravity="center">

            <ImageView
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/banner_oficial"
                android:layout_marginBottom="32dp" />

            <ProgressBar
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:indeterminateTint="#FFC107" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sincronizando Catálogo..."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
