<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111114">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <RelativeLayout
                android:id="@+id/heroSection"
                android:layout_width="match_parent"
                android:layout_height="380dp"> <ImageView
                    android:id="@+id/heroImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="#222222" />

                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_details_gradient" />
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_hero_gradient" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="24dp"> <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_alignParentStart="true"
                        android:gravity="center_vertical">

                        <TextView android:id="@+id/menuPesquisar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pesquisar" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/menuInicio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/menuCanais" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais de TV" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/menuFilmes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Filmes" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/menuSeries" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/menuEsportes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Esportes" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginEnd="8dp"/>
                        <TextView android:id="@+id/menuConfig" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Configurações" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:focusable="true" android:clickable="true" android:background="@drawable/bg_menu_focus" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        
                        <TextView
                            android:id="@+id/tvNetworkStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Conectado"
                            android:textColor="#2ED573"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp"/>

                        <TextView
                            android:id="@+id/tvClock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/textosDestaqueContainer"
                    android:layout_width="600dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical"
                    android:paddingStart="48dp"
                    android:paddingEnd="48dp"
                    android:paddingBottom="32dp"> <TextView android:id="@+id/heroBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CARREGANDO..." android:textColor="#FFC107" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp" />
                    <TextView android:id="@+id/heroTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Aguarde" android:textColor="#FFFFFF" android:textSize="48sp" android:textStyle="bold" android:fontFamily="sans-serif-black" android:layout_marginBottom="8dp" android:maxLines="2" android:ellipsize="end" />
                    <TextView android:id="@+id/heroDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Conectando ao servidor..." android:textColor="#E0E0E0" android:textSize="16sp" android:layout_marginBottom="24dp" android:maxLines="3" android:ellipsize="end" />
                    
                    <Button android:id="@+id/btnAssistirDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:text="▶ ASSISTIR AGORA" android:textStyle="bold" android:textSize="16sp" android:paddingStart="32dp" android:paddingEnd="32dp" android:paddingTop="12dp" android:paddingBottom="12dp" android:visibility="gone" />
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_below="@id/heroSection"
                android:paddingStart="48dp"
                android:paddingTop="24dp"
                android:paddingBottom="48dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/btnGuiaEpg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:layout_marginEnd="48dp"
                    android:background="@drawable/bg_glass"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:background="#FF4757"
                        android:padding="12dp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Guia de Programação"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Veja o que está passando agora nos canais"
                            android:textColor="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="#FF4757"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="16dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tvFavoritosTitulo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais Favoritos" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" android:visibility="gone" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerFavoritos" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/cardRetomar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:layout_marginEnd="48dp"
                    android:background="@drawable/bg_glass"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:visibility="gone"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imgRetomar"
                        android:layout_width="100dp"
                        android:layout_height="150dp"
                        android:scaleType="centerCrop"
                        android:background="#222222" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱ RETOMAR CONTEÚDO"
                            android:textColor="#FF4757"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvRetomarTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nome do Filme"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvRetomarInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Faltam X min"
                            android:textColor="#AAAAAA"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp" />

                        <ProgressBar
                            android:id="@+id/progressRetomar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginEnd="48dp"
                            android:max="100"
                            android:progressTint="#FF4757"
                            android:progressBackgroundTint="#44FFFFFF" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="24dp"
                        android:src="@android:drawable/ic_media_play"
                        android:background="@drawable/bg_btn_yellow"
                        android:padding="16dp" />
                </LinearLayout>

                <TextView android:id="@+id/tvContinuarTitulo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Continuar Assistindo" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" android:visibility="gone" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerContinuar" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" android:visibility="gone" />

                <TextView android:id="@+id/tvAppsTitulo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seus Aplicativos" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerApps" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Últimos Adicionados" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerUltimos" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top 10 Filmes" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerTopFilmes" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />
                    
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries em Alta" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerSeriesAlta" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Top 10 Séries" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerTopSeries" android:scrollbars="none" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:clipChildren="false" android:clipToPadding="false" android:paddingEnd="80dp" />

            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#111114"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerInParent="true"
            android:gravity="center">

            <ImageView android:layout_width="350dp" android:layout_height="wrap_content" android:adjustViewBounds="true" android:src="@drawable/banner_oficial" android:layout_marginBottom="32dp" />
            <ProgressBar android:layout_width="60dp" android:layout_height="60dp" android:indeterminateTint="#FFC107" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sincronizando Catálogo..." android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="16dp" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
