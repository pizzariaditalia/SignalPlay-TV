<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_marginEnd="15dp">

    <TextView
        android:id="@+id/txtRankTop10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="#22222a"
        android:textSize="140sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginStart="0dp"
        android:shadowColor="#444455"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2" />

    <LinearLayout
        android:id="@+id/boxCardInterno"
        android:layout_width="130dp"
        android:layout_height="190dp"
        android:layout_marginStart="45dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_card_premium_normal"
        android:padding="3dp">

        <ImageView
            android:id="@+id/imgCapaPremium"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A24" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TOP"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="#E50914"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_alignTop="@id/boxCardInterno"
        android:layout_alignEnd="@id/boxCardInterno"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:elevation="5dp"/>
</RelativeLayout>
