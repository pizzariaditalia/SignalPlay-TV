<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:focusable="true" android:focusableInTouchMode="true" android:layout_marginEnd="15dp">

    <TextView android:id="@+id/txtRankTop10" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="#111114" android:textSize="140sp" android:textStyle="bold" android:layout_marginTop="20dp" android:shadowColor="#333344" android:shadowDx="-3" android:shadowDy="0" android:shadowRadius="1" />

    <LinearLayout android:id="@+id/boxCardInterno" android:layout_width="140dp" android:layout_height="210dp" android:layout_marginStart="45dp" android:layout_marginTop="10dp" android:background="@drawable/bg_card_glass" android:padding="4dp">
        <ImageView android:id="@+id/imgCapaPremium" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:background="#1A1A24" />
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOP 10" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:background="#E50914" android:paddingStart="6dp" android:paddingEnd="6dp" android:paddingTop="2dp" android:paddingBottom="2dp" android:layout_alignTop="@id/boxCardInterno" android:layout_alignEnd="@id/boxCardInterno" android:layout_marginTop="10dp" android:layout_marginEnd="10dp"/>
</RelativeLayout>
