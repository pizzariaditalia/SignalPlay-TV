<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111114">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/banner_tv"
        android:scaleType="centerCrop"
        android:alpha="0.10" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:paddingTop="40dp"
        android:paddingEnd="50dp">

        <TextView
            android:id="@+id/btnFalarConosco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Falar Conosco"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="30dp"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnAssinatura"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assinatura"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:focusable="true"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="80dp"
        android:background="#B3000000"
        android:orientation="vertical"
        android:padding="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SignalPlay"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="35dp"/>

        <EditText
            android:id="@+id/inputUser"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#333333"
            android:hint="Usuário"
            android:textColorHint="#8C8C8C"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="15dp"
            android:textSize="16sp"
            android:layout_marginBottom="15dp"
            android:inputType="textNoSuggestions"
            android:focusable="true"/>

        <EditText
            android:id="@+id/inputPass"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:background="#333333"
            android:hint="Senha"
            android:textColorHint="#8C8C8C"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="15dp"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:layout_marginBottom="35dp"
            android:focusable="true"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Entrar"
            android:textColor="#111114"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FFCC00"
            android:focusable="true"/>
        
        <ProgressBar
            android:id="@+id/loginLoading"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:indeterminateTint="#FFCC00"
            android:visibility="gone"/>

    </LinearLayout>
</RelativeLayout>
