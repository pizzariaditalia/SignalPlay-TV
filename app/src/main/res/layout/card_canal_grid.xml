<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:focusable="true"
    android:layout_margin="8dp">

    <RelativeLayout 
        android:id="@+id/boxCardInterno"
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:background="@drawable/bg_tv_card_selector"
        android:duplicateParentState="true"
        android:padding="4dp">

        <ImageView 
            android:id="@+id/imgCapaPremium"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:background="#1A1A24"
            android:layout_centerInParent="true"
            android:padding="8dp" />

        <TextView
            android:id="@+id/iconFavStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐"
            android:textSize="14sp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_margin="4dp"
            android:alpha="0.2" />
    </RelativeLayout>

    <TextView 
        android:id="@+id/txtNomePremium"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Carregando..."
        android:textColor="#f5f5f7"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAlignment="center"
        android:layout_marginTop="8dp"/>
</LinearLayout>
