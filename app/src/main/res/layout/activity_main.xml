<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0F">

    <ImageView
        android:id="@+id/imgBackgroundDestaque"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:scaleType="centerCrop"
        android:background="#1A1A24"
        android:alpha="0.4"/>

    <LinearLayout
        android:id="@+id/menuTopo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="30dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/navSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_marginEnd="15dp"/>

        <TextView
            android:id="@+id/navInicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Início"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_marginEnd="15dp"/>

        <TextView
            android:id="@+id/navCanais"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Canais"
            android:textColor="#888888"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_marginEnd="15dp"/>

        <TextView
            android:id="@+id/navFilmes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filmes"
            android:textColor="#888888"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_marginEnd="15dp"/>

        <TextView
            android:id="@+id/navSeries"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Séries"
            android:textColor="#888888"
            android:textSize="18sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/navGuia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/navConfig"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="10dp"
            android:layout_marginEnd="20dp"/>

        <TextView
            android:id="@+id/navPerfil"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:text="BR"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:backgroundTint="#FFCC00"
            android:background="@android:drawable/btn_default"
            android:focusable="true"
            android:focusableInTouchMode="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/areaDestaque"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/menuTopo"
        android:paddingStart="50dp"
        android:layout_marginTop="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EM DESTAQUE"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="#444455"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:text="Super Mario Galaxy: O Filme (2026)"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold"
            android:lineSpacingExtra="-5dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filmes | Lançamentos 2026"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="25dp"/>

        <Button
            android:id="@+id/btnAssistirDestaque"
            android:layout_width="180dp"
            android:layout_height="55dp"
            android:text="▶ Assistir"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:elevation="10dp"/>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/areaDestaque"
        android:layout_marginTop="50dp"
        android:paddingStart="50dp"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continuar Assistindo"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="15dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:id="@+id/card1"
                    android:layout_width="150dp"
                    android:layout_height="220dp"
                    android:background="#222230"
                    android:layout_marginEnd="15dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"/>
                    
                <View
                    android:id="@+id/card2"
                    android:layout_width="150dp"
                    android:layout_height="220dp"
                    android:background="#222230"
                    android:layout_marginEnd="15dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"/>

                <View
                    android:id="@+id/card3"
                    android:layout_width="150dp"
                    android:layout_height="220dp"
                    android:background="#222230"
                    android:layout_marginEnd="15dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"/>
                    
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>
</RelativeLayout>
