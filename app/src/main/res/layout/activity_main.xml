<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111114">

    <!-- Tela Principal do App -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:visibility="invisible"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/imgBackgroundDestaque"
                android:layout_width="match_parent"
                android:layout_height="600dp"
                android:scaleType="centerCrop"
                android:alpha="0.5" />

            <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_alignBottom="@id/imgBackgroundDestaque"
                android:background="@drawable/gradient_hero_bottom" />

            <!-- Menu Superior Otimizado -->
            <LinearLayout
                android:id="@+id/menuTopo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:orientation="horizontal"
                android:paddingTop="30dp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:gravity="center_vertical">

                <ImageView android:id="@+id/navSearch" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_search" android:layout_marginEnd="20dp" android:focusable="true" android:padding="4dp"/>
                <TextView android:id="@+id/navInicio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:padding="10dp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/navCanais" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais" android:textColor="#888888" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:padding="10dp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/navFilmes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Filmes" android:textColor="#888888" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:padding="10dp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/navSeries" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries" android:textColor="#888888" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:padding="10dp" android:layout_weight="1"/>
                
                <TextView android:id="@+id/navPerfil" android:layout_width="45dp" android:layout_height="45dp" android:text="BR" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_perfil_amarelo" android:focusable="true"/>
            </LinearLayout>

            <!-- Painel de Destaque -->
            <LinearLayout
                android:id="@+id/boxDestaque"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="240dp"
                android:orientation="vertical"
                android:paddingStart="50dp"
                android:layout_marginBottom="40dp">
                
                <TextView android:id="@+id/badgeDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EM DESTAQUE" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:background="#444455" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:layout_marginBottom="10dp" android:visibility="invisible"/>
                <TextView android:id="@+id/txtTituloDestaque" android:layout_width="550dp" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="44sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/txtDescDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CCCCCC" android:textSize="15sp" android:layout_marginBottom="25dp"/>
                <Button android:id="@+id/btnAssistirDestaque" android:layout_width="180dp" android:layout_height="50dp" android:text="▶ Assistir" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" android:background="@drawable/bg_botao_branco" android:focusable="true" android:visibility="invisible"/>
            </LinearLayout>

            <!-- Trilhos de Conteúdo -->
            <LinearLayout
                android:id="@+id/containerTrilhos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/imgBackgroundDestaque"
                android:layout_marginTop="-20dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingBottom="40dp" />
        </RelativeLayout>
    </ScrollView>

    <!-- Indicador de Carregamento Nativo Super Leve (Substitui o Shimmer) -->
    <RelativeLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#111114"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:indeterminateTint="#FFCC00"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carregando catálogo..."
                android:textColor="#888888"
                android:textSize="14sp"
                android:layout_marginTop="15dp"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Modal de Configurações e Perfil Simples -->
    <RelativeLayout
        android:id="@+id/modalPerfilOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:visibility="gone"
        android:elevation="20dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_panel"
            android:padding="30dp"
            android:gravity="center_horizontal">

            <Button android:id="@+id/btnModalFechar" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="end" android:text="✕" android:textColor="#FFFFFF" android:background="@android:color/transparent" android:focusable="true"/>
            <TextView android:id="@+id/txtModalAvatar" android:layout_width="70dp" android:layout_height="70dp" android:textColor="#000000" android:textSize="24sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_perfil_amarelo" android:layout_marginTop="-10dp" android:layout_marginBottom="10dp"/>
            <TextView android:id="@+id/txtModalNome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"/>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginVertical="15dp">
                <TextView android:id="@+id/txtModalVencimento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="12sp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/txtModalTelas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnModalParental" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:focusable="true" android:padding="12dp" android:background="@drawable/bg_config_item">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Controle Parental" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ocultar canais e filmes adultos" android:textColor="#888888" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/switchParental" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:clickable="false" android:focusable="false" android:thumbTint="#FFCC00"/>
            </LinearLayout>

            <Button android:id="@+id/btnModalLogout" android:layout_width="match_parent" android:layout_height="45dp" android:text="Desconectar" android:textColor="#FF4757" android:textSize="14sp" android:textStyle="bold" android:background="@drawable/bg_btn_logout" android:layout_marginTop="20dp" android:focusable="true"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
