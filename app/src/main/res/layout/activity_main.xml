<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <ImageView android:id="@+id/imgBackgroundDestaque" android:layout_width="match_parent" android:layout_height="650dp" android:scaleType="centerCrop" android:alpha="0.6"/>
    <View android:layout_width="match_parent" android:layout_height="300dp" android:layout_below="@id/imgBackgroundDestaque" android:layout_marginTop="-300dp" android:background="@drawable/gradient_hero_bottom" />
    <View android:layout_width="match_parent" android:layout_height="120dp" android:background="@drawable/gradient_menu_topo" />

    <LinearLayout
        android:id="@+id/menuTopo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="30dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:gravity="center_vertical">

        <ImageView android:id="@+id/navSearch" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_search" android:layout_marginEnd="20dp" android:focusable="true" android:focusableInTouchMode="true" android:padding="4dp"/>
        <TextView android:id="@+id/navInicio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="true" android:padding="10dp" android:layout_marginEnd="15dp"/>
        <TextView android:id="@+id/navCanais" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="true" android:padding="10dp" android:layout_marginEnd="15dp"/>
        <TextView android:id="@+id/navFilmes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Filmes" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="true" android:padding="10dp" android:layout_marginEnd="15dp"/>
        <TextView android:id="@+id/navSeries" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="true" android:padding="10dp" android:layout_weight="1"/>
        
        <TextView android:id="@+id/navPerfil" android:layout_width="45dp" android:layout_height="45dp" android:text="BR" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_perfil_amarelo" android:focusable="true" android:focusableInTouchMode="true"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@id/menuTopo" android:clipChildren="false" android:clipToPadding="false" android:scrollbars="none">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:clipChildren="false" android:clipToPadding="false" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="50dp" android:paddingTop="50dp" android:layout_marginBottom="120dp">
                <TextView android:id="@+id/badgeDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EM DESTAQUE" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:background="#444455" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_marginBottom="10dp" android:visibility="invisible"/>
                <TextView android:id="@+id/txtTituloDestaque" android:layout_width="600dp" android:layout_height="wrap_content" android:text="" android:textColor="#FFFFFF" android:textSize="48sp" android:textStyle="bold" android:lineSpacingExtra="-5dp" android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/txtDescDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#CCCCCC" android:textSize="16sp" android:layout_marginBottom="35dp"/>
                <Button android:id="@+id/btnAssistirDestaque" android:layout_width="200dp" android:layout_height="60dp" android:text="▶ Assistir" android:textColor="#000000" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_botao_branco" android:focusable="true" android:focusableInTouchMode="true" android:visibility="invisible"/>
            </LinearLayout>
            <LinearLayout android:id="@+id/containerTrilhos" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:clipChildren="false" android:clipToPadding="false" android:layout_marginTop="-80dp" android:paddingBottom="50dp"/>
        </LinearLayout>
    </ScrollView>

    <RelativeLayout
        android:id="@+id/modalPerfilOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:visibility="gone"
        android:elevation="20dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="450dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_premium_normal"
            android:backgroundTint="#F2111114"
            android:padding="30dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/txtModalAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="BR"
                android:textColor="#000000"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_perfil_amarelo"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:id="@+id/txtModalNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olá, Cliente!"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTA ATIVA"
                android:textColor="#2ed573"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="#332ed573"
                android:layout_marginBottom="25dp"/>

            <Button android:id="@+id/btnModalLimparHist" android:layout_width="match_parent" android:layout_height="50dp" android:text="🗑️ Limpar Histórico" android:textColor="#FFFFFF" android:background="@android:color/transparent" android:textAlignment="viewStart" android:focusable="true" android:focusableInTouchMode="true"/>
            <Button android:id="@+id/btnModalLimparFavs" android:layout_width="match_parent" android:layout_height="50dp" android:text="⭐ Zerar Favoritos" android:textColor="#FFFFFF" android:background="@android:color/transparent" android:textAlignment="viewStart" android:focusable="true" android:focusableInTouchMode="true"/>
            <Button android:id="@+id/btnModalLogout" android:layout_width="match_parent" android:layout_height="50dp" android:text="🚪 Desconectar Conta" android:textColor="#ff4757" android:background="@android:color/transparent" android:textAlignment="viewStart" android:focusable="true" android:focusableInTouchMode="true" android:layout_marginBottom="15dp"/>
            <Button android:id="@+id/btnModalFechar" android:layout_width="match_parent" android:layout_height="50dp" android:text="VOLTAR" android:textColor="#000000" android:textStyle="bold" android:background="@drawable/bg_botao_branco" android:focusable="true" android:focusableInTouchMode="true"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
