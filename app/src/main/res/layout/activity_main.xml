<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/imgFundoLogin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_parede_tvs" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_gradient" />

    <LinearLayout
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="80dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrar"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/edtUrl"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="URL do Servidor (http://...)"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="@drawable/bg_input_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:nextFocusDown="@+id/edtUser" />

        <EditText
            android:id="@+id/edtUser"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Usuário"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="@drawable/bg_input_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp"
            android:singleLine="true"
            android:textSize="16sp"
            android:nextFocusDown="@+id/edtPass" />

        <EditText
            android:id="@+id/edtPass"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:hint="Senha"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="@drawable/bg_input_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="32dp"
            android:singleLine="true"
            android:inputType="textPassword"
            android:textSize="16sp"
            android:nextFocusDown="@+id/btnLogin" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Entrar"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_yellow"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginBottom="16dp"
            android:nextFocusDown="@+id/chkLembrar" />

        <CheckBox
            android:id="@+id/chkLembrar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lembre-se de mim"
            android:textColor="#B3B3B3"
            android:textSize="16sp"
            android:buttonTint="#FFC107"
            android:focusable="true" />

        <ProgressBar
            android:id="@+id/progressBarLogin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:indeterminateTint="#FFC107"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Versão do App"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>
</RelativeLayout>
