<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:visibility="invisible"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/imgBackgroundDestaque"
                android:layout_width="match_parent"
                android:layout_height="650dp"
                android:scaleType="centerCrop"
                android:alpha="0.6" />

            <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_alignBottom="@id/imgBackgroundDestaque"
                android:background="@drawable/gradient_hero_bottom" />

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_alignParentTop="true"
                android:background="@drawable/gradient_menu_topo" />

            <LinearLayout
                android:id="@+id/menuTopo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:orientation="horizontal"
                android:paddingTop="30dp"
                android:paddingStart="40dp"
                android:paddingEnd="40dp"
                android:gravity="center_vertical">

                <ImageView android:id="@+id/navSearch" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_menu_search" android:layout_marginEnd="20dp" android:focusable="true" android:focusableInTouchMode="false" android:padding="4dp"/>
                <TextView android:id="@+id/navInicio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="false" android:padding="10dp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/navCanais" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Canais" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="false" android:padding="10dp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/navFilmes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Filmes" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="false" android:padding="10dp" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/navSeries" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Séries" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="false" android:padding="10dp" android:layout_marginEnd="15dp"/>
                
                <TextView android:id="@+id/navGuia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Guia de TV" android:textColor="@color/text_muted" android:textSize="18sp" android:textStyle="bold" android:focusable="true" android:focusableInTouchMode="false" android:padding="10dp" android:layout_weight="1"/>
                
                <TextView android:id="@+id/navPerfil" android:layout_width="45dp" android:layout_height="45dp" android:text="BR" android:textColor="#000000" android:textSize="16sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_perfil_amarelo" android:focusable="true" android:focusableInTouchMode="false"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/boxDestaque"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="270dp"
                android:orientation="vertical"
                android:paddingStart="50dp"
                android:paddingTop="50dp"
                android:layout_marginBottom="80dp">
                
                <TextView android:id="@+id/badgeDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EM DESTAQUE" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" android:background="#444455" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_marginBottom="10dp" android:visibility="invisible"/>
                <TextView android:id="@+id/txtTituloDestaque" android:layout_width="600dp" android:layout_height="wrap_content" android:text="" android:textColor="#FFFFFF" android:textSize="48sp" android:textStyle="bold" android:lineSpacingExtra="-5dp" android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/txtDescDestaque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textColor="#CCCCCC" android:textSize="16sp" android:layout_marginBottom="35dp"/>
                <Button android:id="@+id/btnAssistirDestaque" android:layout_width="200dp" android:layout_height="60dp" android:text="▶ Assistir" android:textColor="#000000" android:textSize="18sp" android:textStyle="bold" android:background="@drawable/bg_botao_branco" android:focusable="true" android:focusableInTouchMode="false" android:visibility="invisible"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerTrilhos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/imgBackgroundDestaque"
                android:layout_marginTop="-40dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingBottom="50dp" />
        </RelativeLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/shimmerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_base">
        
        <View android:layout_width="match_parent" android:layout_height="400dp" android:background="#1A1A24" android:layout_marginBottom="20dp"/>
        <View android:layout_width="200dp" android:layout_height="20dp" android:background="#1A1A24" android:layout_marginStart="50dp" android:layout_marginBottom="15dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="50dp" android:layout_marginBottom="30dp">
            <View android:layout_width="140dp" android:layout_height="210dp" android:background="#1A1A24" android:layout_marginEnd="15dp"/>
            <View android:layout_width="140dp" android:layout_height="210dp" android:background="#1A1A24" android:layout_marginEnd="15dp"/>
            <View android:layout_width="140dp" android:layout_height="210dp" android:background="#1A1A24" android:layout_marginEnd="15dp"/>
            <View android:layout_width="140dp" android:layout_height="210dp" android:background="#1A1A24" android:layout_marginEnd="15dp"/>
            <View android:layout_width="140dp" android:layout_height="210dp" android:background="#1A1A24" android:layout_marginEnd="15dp"/>
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/modalPerfilOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000"
        android:visibility="gone"
        android:elevation="30dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="450dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_panel"
            android:padding="35dp"
            android:gravity="center_horizontal">

            <Button android:id="@+id/btnModalFechar" android:layout_width="35dp" android:layout_height="35dp" android:layout_gravity="end" android:text="✕" android:textColor="#FFFFFF" android:textSize="16sp" android:background="@android:color/transparent" android:focusable="true" android:focusableInTouchMode="false"/>
            <TextView android:id="@+id/txtModalAvatar" android:layout_width="80dp" android:layout_height="80dp" android:text="BR" android:textColor="#000000" android:textSize="28sp" android:textStyle="bold" android:gravity="center" android:background="@drawable/bg_perfil_amarelo" android:layout_marginTop="-20dp" android:layout_marginBottom="10dp"/>
            <TextView android:id="@+id/txtModalNome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Olá, Cliente!" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtStatusConta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONTA ATIVA" android:textColor="#2ed573" android:textSize="10sp" android:textStyle="bold" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:background="@drawable/bg_badge_ativo" android:layout_marginTop="5dp" android:layout_marginBottom="15dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#1A000000" android:padding="10dp" android:gravity="center" android:layout_marginBottom="25dp">
                <TextView android:id="@+id/txtModalVencimento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vencimento: --/--/----" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginEnd="15dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="|" android:textColor="#4DFFFFFF" android:layout_marginEnd="15dp"/>
                <TextView android:id="@+id/txtModalTelas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Telas: 1 / Ilimitado" android:textColor="#FFFFFF" android:textSize="12sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnModalParental" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:focusable="true" android:focusableInTouchMode="false" android:padding="12dp" android:background="@drawable/bg_config_item">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Controle Parental" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ocultar conteúdo adulto (+18)" android:textColor="#8e8e93" android:textSize="11sp"/>
                </LinearLayout>
                <Switch android:id="@+id/switchParental" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:clickable="false" android:focusable="false" android:thumbTint="@color/accent_yellow"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnModalLimparHist" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:focusable="true" android:focusableInTouchMode="false" android:padding="12dp" android:background="@drawable/bg_config_item" android:layout_marginTop="5dp">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Limpar Histórico" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zerar 'Continuar Assistindo'" android:textColor="#8e8e93" android:textSize="11sp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🗑️" android:textColor="#8e8e93" android:textSize="14sp" android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnModalLimparFavs" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:focusable="true" android:focusableInTouchMode="false" android:padding="12dp" android:background="@drawable/bg_config_item" android:layout_marginTop="5dp">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zerar Favoritos" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Remover canais salvos" android:textColor="#8e8e93" android:textSize="11sp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textColor="#8e8e93" android:textSize="14sp" android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <Button android:id="@+id/btnModalUpdateEpg" android:layout_width="match_parent" android:layout_height="50dp" android:text="🔄 Atualizar Guia de TV (EPG)" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" android:background="@drawable/bg_btn_yellow" android:layout_marginTop="15dp" android:focusable="true" android:focusableInTouchMode="false"/>
            <Button android:id="@+id/btnModalLogout" android:layout_width="match_parent" android:layout_height="50dp" android:text="Desconectar Conta" android:textColor="#ff4757" android:textSize="14sp" android:textStyle="bold" android:background="@drawable/bg_btn_logout" android:layout_marginTop="15dp" android:focusable="true" android:focusableInTouchMode="false"/>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
