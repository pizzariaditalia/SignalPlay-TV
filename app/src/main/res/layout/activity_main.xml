<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:padding="48dp">

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:src="@drawable/signal"
        android:scaleType="centerInside"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true" />

    <TextView
        android:id="@+id/faleConoscoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fale Conosco"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:focusable="true"
        android:clickable="true"
        android:layout_alignParentEnd="true"
        android:layout_alignTop="@id/logoImage"
        android:layout_alignBottom="@id/logoImage"
        android:gravity="center_vertical" />

    <LinearLayout
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/logoImage"
        android:layout_alignParentStart="true"
        android:layout_marginTop="64dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrar"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="#333333"
            android:hint="Email ou número de telefone"
            android:textColorHint="#8C8C8C"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:textSize="18sp"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"
            android:focusable="true" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="#333333"
            android:hint="Senha"
            android:textColorHint="#8C8C8C"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="20dp"
            android:textSize="18sp"
            android:inputType="textPassword"
            android:layout_marginBottom="32dp"
            android:focusable="true" />

        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:backgroundTint="#FFC107"
            android:text="Entrar"
            android:textColor="#1a1a1a"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:focusable="true"
            android:layout_marginBottom="16dp" />

        <CheckBox
            android:id="@+id/rememberMeCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lembre-se de mim"
            android:textColor="#B3B3B3"
            android:buttonTint="#FFC107"
            android:textSize="16sp"
            android:focusable="true" />

    </LinearLayout>

</RelativeLayout>
