<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false" />

    <ProgressBar
        android:id="@+id/loadingSpinner"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="#ffcc00" />

    <RelativeLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:orientation="horizontal"
            android:padding="30dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_menu_topo">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬅ VOLTAR"
                android:textColor="#ffcc00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginEnd="20dp" />

            <TextView
                android:id="@+id/txtPlayerTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carregando..."
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtFeedbackAvanco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="+10s ⏩"
            android:textColor="#ffcc00"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:padding="40dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_hero_bottom">

            <ImageView
                android:id="@+id/btnPlayPauseIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_media_pause"
                android:tint="#ffcc00"
                android:layout_marginEnd="15dp"/>

            <TextView
                android:id="@+id/txtTempoAtual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/progressBarTempo"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:progressTint="#ffcc00"
                android:progressBackgroundTint="#444455" />

            <TextView
                android:id="@+id/txtTempoTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#8e8e93"
                android:textSize="14sp" />
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
