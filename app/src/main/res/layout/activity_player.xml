<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.google.android.exoplayer2.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit"
        app:use_controller="false" />

    <ProgressBar
        android:id="@+id/loadingSpinner"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="#ffcc00" />

    <RelativeLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:orientation="horizontal"
            android:padding="30dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_menu_topo">

            <ImageView
                android:id="@+id/imgOsdLogo"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="#33FFFFFF"
                android:padding="5dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="20dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtPlayerTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtOsdEpgAtual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buscando programação..."
                    android:textColor="#ffcc00"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/txtOsdEpgProx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#8e8e93"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:padding="30dp"
            android:background="@drawable/gradient_hero_bottom">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnPlayPauseIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_pause"
                    android:tint="#ffcc00"
                    android:layout_marginEnd="15dp"/>

                <TextView
                    android:id="@+id/txtTempoAtual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <ProgressBar
                    android:id="@+id/progressBarTempo"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:progressTint="#ffcc00"
                    android:progressBackgroundTint="#444455" />

                <TextView
                    android:id="@+id/txtTempoTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#8e8e93"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="20dp">

                <Button
                    android:id="@+id/btnModalEpg"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="📅 EPG"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_card_premium_normal"
                    android:focusable="true"
                    android:focusableInTouchMode="true"/>

                <Button
                    android:id="@+id/btnModalPlaylist"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="📑 PLAYLIST"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_card_premium_normal"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_marginStart="10dp"/>

                <Button
                    android:id="@+id/btnAjustar"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="AJUSTAR"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#ffcc00"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_marginStart="10dp"/>

                <Button
                    android:id="@+id/btnEsticar"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="ESTICAR"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_card_premium_normal"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/panelPlaylist"
        android:layout_width="350dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:background="#EE111114"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        android:elevation="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📑 Canais da Categoria"
            android:textColor="#ffcc00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelEpg"
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:background="#EE111114"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        android:elevation="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Guia de Programação"
            android:textColor="#ffcc00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEpg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txtFeedbackAvanco"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="+10s ⏩"
        android:textColor="#ffcc00"
        android:textSize="24sp"
        android:textStyle="bold"
        android:visibility="gone"/>

</RelativeLayout>
