<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_marginEnd="15dp">

    <RelativeLayout
        android:id="@+id/boxCardInterno"
        android:layout_width="140dp"
        android:layout_height="210dp"
        android:background="@drawable/bg_card_premium_normal"
        android:padding="3dp">

        <ImageView
            android:id="@+id/imgCapaPremium"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A24" />

        <ProgressBar
            android:id="@+id/progressoFilme"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_alignParentBottom="true"
            android:progressTint="#ffcc00"
            android:progressBackgroundTint="#444455" />
    </RelativeLayout>

    <TextView
        android:id="@+id/txtNomePremium"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:text="Carregando..."
        android:textColor="#f5f5f7"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAlignment="center"
        android:layout_marginTop="8dp"/>
</LinearLayout>
