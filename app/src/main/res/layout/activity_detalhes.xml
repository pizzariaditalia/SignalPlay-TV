<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <ImageView
        android:id="@+id/imgFundoDetalhes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.3"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_menu_topo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="50dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgPosterDetalhes"
            android:layout_width="220dp"
            android:layout_height="330dp"
            android:scaleType="centerCrop"
            android:background="#22222a"
            android:elevation="10dp"
            android:layout_marginEnd="40dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTituloDetalhes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carregando..."
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/txtMetaDetalhes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 ----   ⭐ 0.0   FILME"
                android:textColor="#ffcc00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:id="@+id/txtSinopseDetalhes"
                android:layout_width="600dp"
                android:layout_height="wrap_content"
                android:text="Aguarde..."
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:maxLines="6"
                android:ellipsize="end"
                android:layout_marginBottom="40dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnAssistirDetalhes"
                    android:layout_width="250dp"
                    android:layout_height="60dp"
                    android:text="▶ ASSISTIR"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_botao_branco"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:layout_marginEnd="20dp"/>

                <Button
                    android:id="@+id/btnVoltarDetalhes"
                    android:layout_width="120dp"
                    android:layout_height="60dp"
                    android:text="VOLTAR"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="#333344"
                    android:focusable="true"
                    android:focusableInTouchMode="false"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
