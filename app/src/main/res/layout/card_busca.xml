<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_marginEnd="15dp"
    android:layout_marginBottom="15dp">

    <LinearLayout
        android:id="@+id/boxCardInterno"
        android:layout_width="140dp"
        android:layout_height="210dp"
        android:background="@drawable/bg_card_glass"
        android:padding="4dp">

        <ImageView
            android:id="@+id/imgCapaPremium"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A24" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtBadgeTipo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIPO"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="#E50914"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_alignTop="@id/boxCardInterno"
        android:layout_alignEnd="@id/boxCardInterno"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:elevation="5dp"/>

    <TextView
        android:id="@+id/txtNomePremium"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/boxCardInterno"
        android:text="Carregando..."
        android:textColor="#f5f5f7"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAlignment="center"
        android:layout_marginTop="8dp"/>
</RelativeLayout>
